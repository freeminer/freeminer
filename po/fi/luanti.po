#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "$1 spread"
msgstr "$1-levitys"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "(No description of setting given)"
msgstr "(Asetukselle ei ole kirjoitettu kuvausta)"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "2D Noise"
msgstr "2D-kohina"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"2D noise: flag on.\n"
"3D noise: flag off."
msgstr ""
"2D-kohina: lippu päällä.\n"
"3D-kohina: lippu pois päältä."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"Amplifies every octave by (amplitude of the previous octave * Persistence)."
msgstr ""
"Vahvistuu jokaisella oktaavilla seuraavan arvon verran: edellisen oktaavin "
"taajuus * pysyvyys."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
#: builtin/mainmenu/content/dlg_install.lua
#: builtin/mainmenu/content/dlg_overwrite.lua
#: builtin/mainmenu/dlg_config_world.lua builtin/mainmenu/dlg_confirm_exit.lua
#: builtin/mainmenu/dlg_create_world.lua
#: builtin/mainmenu/dlg_delete_content.lua
#: builtin/mainmenu/dlg_delete_world.lua builtin/mainmenu/dlg_register.lua
#: builtin/mainmenu/dlg_rename_modpack.lua src/gui/guiOpenURL.cpp
#: src/gui/guiPasswordChange.cpp
msgid "Cancel"
msgstr "Peruuta"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Controls how many octaves (layers) the noise will have."
msgstr "Määrittää, kuinka monta oktaavia (kerrosta) kohinalla on."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"Each octave is a simple noise generator. Each one also adds more detail to "
"the noise."
msgstr ""
"Jokainen oktaavi on yksinkertainen kohinageneraattori. Kukin lisää kohinaan "
"yksityiskohtia."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Finally, all of the octaves will be combined to generate the noise."
msgstr "Lopulta kaikki oktaavit yhdistetään kohinan luomiseksi."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"Having lots of octaves is not recommended because it increases terrain "
"generation time."
msgstr ""
"Ei ole suositeltavaa käyttää suurta määrää oktaaveja, koska se pidentää "
"maaston luomiseen kuluvaa aikaa."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Lacunarity"
msgstr "Rakoilevuus"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"Lower values make the terrain simple and higher values make the terrain "
"rough."
msgstr ""
"Mitä pienempi arvo on, sitä yksinkertaisempi maasto on. Mitä suurempi arvo "
"on, sitä rosoisempi maasto on."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"Lower values make the terrain smooth and higher values make the terrain have "
"fine detail."
msgstr ""
"Mitä pienempi arvo on, sitä tasaisempi maasto on. Mitä suurempi arvo on, "
"sitä yksityiskohtaisempi maasto on."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"Lower values will result in smoother noise and higher values will result in "
"rougher noise."
msgstr ""
"Mitä pienempi arvo on, sitä tasaisempi kohina on. Mitä suurempi arvo on, "
"sitä epätasaisempi kohina on."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"Making 3D noise eased is not recommended because it significantly increases "
"the load."
msgstr ""
"3D-kohinan lieventäminen ei kannata, koska se lisää latausaikaa "
"merkittävästi."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"Maps noise gradient values onto a quintic S-curve before performing "
"interpolation."
msgstr ""
"Luo kohinan kaltevuusarvoista viidennen asteen S-käyrän ennen interpolointia."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Octaves"
msgstr "Oktaavit"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
#: src/settings_translation_file.cpp
msgid "Offset"
msgstr "Siirto"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Offsets the final noise by this value."
msgstr "Siirtää viimeisen kohinan tämän arvon verran."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Overrides the 'eased' flag based on the noise type."
msgstr "Ohittaa \"lievennetty\"-merkinnän kohinalajista riippuen."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Persistence"
msgstr "Pysyvyys"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
#: builtin/mainmenu/dlg_config_world.lua
msgid "Save"
msgstr "Tallenna"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
#: src/settings_translation_file.cpp
msgid "Scale"
msgstr "Laajuus"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Scales every octave by (scale of the previous octave / Lacunarity)."
msgstr ""
"Laajentaa jokaista oktaavia seuraavalla arvolla: edellisen oktaavin "
"laajuus / rakoilevuus."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Scales the noise in the $1 axis by this value."
msgstr "Laajentaa kohinaa $1-akselilla tämän arvon verran."

#. TRANSLATORS: Value for randomness
#: builtin/common/settings/dlg_change_mapgen_flags.lua
#: builtin/mainmenu/dlg_create_world.lua
msgid "Seed"
msgstr "Siemen"

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "Takes the absolute value of each octave while adding them together."
msgstr "Ottaa kunkin oktaavin täyden arvon laskiessaan niitä yhteen."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "The first octave is amplified by 1."
msgstr "Ensimmäinen oktaavi vahvistetaan arvolla 1."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "The first octave is scaled by 1."
msgstr "Ensimmäinen oktaavi laajennetaan arvolla 1."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "The multiplier for the noise before the offset is added."
msgstr "Kohinan kerroin ennen siirron lisäämistä."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "The random seed for the noise. The same seed results in the same noise."
msgstr "Kohinan satunnainen siemen. Sama siemen tuottaa saman kohinan."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid ""
"This is also the scale of the largest structures in the $1 direction of the "
"noise."
msgstr "Tämä on myös suurimpien rakennelmien laajuus kohinan $1-suunnassa."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "This results in smooth noise instead of gridlike noise."
msgstr "Tämä tuottaa tasaisen kohinan ruudukkomaisen kohinan sijaan."

#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "This results in spiky noise."
msgstr "Tämä tuottaa piikikkään kohinan."

#. TRANSLATORS: "absvalue" is a noise parameter flag.
#. It is short for "absolute value".
#. It can be enabled in noise settings in
#. the settings menu.
#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "absvalue"
msgstr "absoluuttinen arvo"

#. TRANSLATORS: "defaults" is a noise parameter flag.
#. It describes the default processing options
#. for noise settings in the settings menu.
#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "defaults"
msgstr "oletukset"

#. TRANSLATORS: "eased" is a noise parameter flag.
#. It is used to make the map smoother and
#. can be enabled in noise settings in
#. the settings menu.
#: builtin/common/settings/dlg_change_mapgen_flags.lua
msgid "eased"
msgstr "lievennetty"

