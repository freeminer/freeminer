msgstr "Tyrmän pienin mahdollinen Y"

#: src/settings_translation_file.cpp
msgid "Dungeon noise"
msgstr "Tyrmäkohina"

#: src/settings_translation_file.cpp
msgid "Dynamic shadows"
msgstr "Dynaamiset varjot"

