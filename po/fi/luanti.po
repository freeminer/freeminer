msgstr ""
"Aktiivisten kuutioiden muuttajien (ABM) suorituskiertojen välinen aika "
"sekunneissa ilmoitettuna."

#: src/settings_translation_file.cpp
msgid "Length of time between NodeTimer execution cycles, stated in seconds."
msgstr ""
"Kuutioajastimen (NodeTimer) suorituskiertojen välinen aika sekunneissa "
"ilmoitettuna."

#: src/settings_translation_file.cpp
msgid ""
"Length of time between active block management cycles, stated in seconds."
msgstr ""
"Aktiivisten kuutioiden hallintakiertojen välinen aika sekunneissa "
"ilmoitettuna."

#: src/settings_translation_file.cpp
msgid ""
"Level of logging to be written to debug.txt:\n"
