"4 = 4D \"Neliömäinen\" Julia-sarja.\n"
"5 = 4D \"Mandy-serkku\" Mandelbrot-sarja.\n"
"6 = 4D \"Mandy-serkku\" Julia-sarja.\n"
"7 = 4D \"Vaihtelu\" Mandelbrot-sarja.\n"
"8 = 4D \"Vaihtelu\" Julia-sarja.\n"
"9 = 3D \"Mandelbrot/Mandelbar\" Mandelbrot-sarja.\n"
"10 = 3D \"Mandelbrot/Mandelbar\" Julia-sarja.\n"
"11 = 3D \"Joulukuusi\" Mandelbrot-sarja.\n"
"12 = 3D \"Joulukuusi\" Julia-sarja.\n"
"13 = 3D \"Mandelbulb\" Mandelbrot-sarja.\n"
"14 = 3D \"Mandelbulb\" Julia-sarja.\n"
"15 = 3D \"Kosini-Mandelbulb\" Mandelbrot-sarja.\n"
"16 = 3D \"Kosini-Mandelbulb\" Julia-sarja.\n"
"17 = 4D \"Mandelbulb\" Mandelbrot-sarja.\n"
"18 = 4D \"Mandelbulb\" Julia-sarja."

#: src/settings_translation_file.cpp
msgid ""
"Send names of online players to the serverlist. If disabled only the player "
"count is revealed."
